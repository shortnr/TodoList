<Window x:Class="TodoList.Src.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TodoList"
        xmlns:views="clr-namespace:TodoList.Src.Views"
        xmlns:vms="clr-namespace:TodoList.Src.ViewModels"
        mc:Ignorable="d"
        Title="ToDos" Height="800" Width="600">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vms:TodoListViewModel}">
            <views:TodoListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:AddTaskViewModel}">
            <views:AddTaskView />
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <ContentControl Content="{Binding CurrentView}" />
    </Grid>
</Window>
