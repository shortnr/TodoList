<UserControl x:Class="TodoList.Src.Views.TodoListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TodoList.Src.Views"
             mc:Ignorable="d"
             d:Background="White"
             d:DesignHeight="800" d:DesignWidth="600">
    <UserControl.Resources>
        <Style x:Key="StretchedListViewItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <GridView x:Key="TaskGridView" x:Shared="False">
            <GridViewColumn Header="Task"      Width="200" DisplayMemberBinding="{Binding TaskName}"/>
            <GridViewColumn Header="Due Date"  Width="100" DisplayMemberBinding="{Binding DueDate}"/>
            <GridViewColumn Header="Priority"  Width="100" DisplayMemberBinding="{Binding Priority}"/>
            <GridViewColumn Header="Completed" Width="100">
                <GridViewColumn.CellTemplate>
                    <DataTemplate>
                        <Grid HorizontalAlignment="Stretch">
                            <CheckBox IsChecked="{Binding Completed}" HorizontalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </GridViewColumn.CellTemplate>
            </GridViewColumn>
        </GridView>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="To-Do List" FontSize="24" FontWeight="Bold" Margin="10" Grid.Row="0" HorizontalAlignment="Center"/>
        
        <Button Command="{Binding DataContext.NavToAddTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Content="Add Task" Width="100" Margin="10" Grid.Column="1" HorizontalAlignment="Right"/>

        <ListView Grid.Row="1" ItemsSource="{Binding TaskItemList}" View="{StaticResource TaskGridView}"
                ItemContainerStyle="{StaticResource StretchedListViewItem}"/>
    </Grid>
</UserControl>
